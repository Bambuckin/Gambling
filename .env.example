# ==============================
# Lottery Runtime Configuration
# ==============================

# in-memory | postgres
LOTTERY_STORAGE_BACKEND=postgres

# Primary PostgreSQL connection used by both web and terminal-worker.
# Replace <DB_HOST_IP> with your database host (or service name in docker compose).
LOTTERY_POSTGRES_URL=postgresql://lottery:lottery@<DB_HOST_IP>:5432/lottery

# Optional fallback alias used by some tools.
DATABASE_URL=

# Worker lock + polling controls
LOTTERY_TERMINAL_LOCK_TTL_SECONDS=30
LOTTERY_TERMINAL_POLL_INTERVAL_MS=3000
LOTTERY_BIG8_LIVE_DRAW_SYNC_ENABLED=true
LOTTERY_BIG8_PURCHASE_AUTOMATION_ENABLED=true
# Backward-compatible alias for older worker builds:
LOTTERY_BIG8_CART_AUTOMATION_ENABLED=
LOTTERY_BIG8_TERMINAL_MODE=real
LOTTERY_BIG8_MOCK_LATENCY_MS=250
LOTTERY_BIG8_DRAW_SYNC_INTERVAL_MS=5000
LOTTERY_TERMINAL_BROWSER_URL=http://127.0.0.1:9222
LOTTERY_TERMINAL_PAGE_URL=https://webapp.cloud.nationallottery.ru/
LOTTERY_BIG8_DRAW_MODAL_WAIT_MS=2500
LOTTERY_BIG8_DRAW_TTL_SECONDS=45
LOTTERY_BIG8_ACTION_TIMEOUT_MS=8000
LOTTERY_BIG8_RELOAD_BEFORE_PURCHASE=true

# Comma-separated list of lottery codes that worker handlers can execute.
LOTTERY_TERMINAL_HANDLER_CODES=mechtallion,bolshaya-8,velikolepnaya-8,super-8,top-12,twelve-good-deeds,lavina-prizov,premier,turnir,trizhdy-tri,four-by-four,forsage-75,pyataya-skorost,five-of-thirty-seven,pyat-o-pyat,cvetnye-shary

# Optional JSON overrides for in-memory mode only (leave empty for defaults)
LOTTERY_ACCESS_IDENTITIES_JSON=
LOTTERY_REGISTRY_ENTRIES_JSON=
LOTTERY_DRAW_SNAPSHOTS_JSON=
LOTTERY_LEDGER_ENTRIES_JSON=

# Next.js host/port
HOSTNAME=0.0.0.0
PORT=3000
