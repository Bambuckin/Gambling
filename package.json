{
  "name": "lottery-terminal-operations-system",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "description": "Foundation workspace for lottery terminal operations system.",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev:web": "corepack pnpm --filter @lottery/web dev",
    "dev:worker": "corepack pnpm --filter @lottery/terminal-worker dev",
    "lint": "corepack pnpm -r --if-present lint",
    "typecheck": "corepack pnpm -r --if-present typecheck",
    "test": "corepack pnpm -r --if-present test",
    "smoke": "corepack pnpm --filter @lottery/test-kit smoke"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "typescript": "^5.8.3",
    "vitest": "2.1.9"
  }
}
